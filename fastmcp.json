{
  "$schema": "https://gofastmcp.com/public/schemas/fastmcp.json/v1.json",
  "source": {
    "path": "server.py",
    "entrypoint": "app"
  },
  "environment": {
    "type": "uv",
    "python": ">=3.10",
    "project": "."
  },
  "deployment": {
    "transport": "http",
    "host": "0.0.0.0",
    "port": 3000,
    "path": "/mcp/",
    "log_level": "INFO",
    "env": {
      "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
    }
  }
}
